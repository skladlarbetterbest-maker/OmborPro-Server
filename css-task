║  6. TYPOGRAPHY (Shrift)                                                    ║
╚═══════════════════════════════════════════════════════════════════════════════╝

Font Family:
  font-family: 'Inter', -apple-system, sans-serif

Font Sizes:
  - Logo/Brand: 22px, weight: 800 (gradient text)
  - Card Title: 16px, weight: 700
  - Nav Item: 14px, weight: 500
  - Body Text: 13px, weight: 400
  - Label: 11px, weight: 600, uppercase, letter-spacing: 1px
  - Stat Value: 28px, weight: 800
  - Mono: 12px (SF Mono, Cascadia Code, Fira Code)

Letter Spacing:
  - Labels: 0.5px - 1px (uppercase)
  - Headings: -0.5px (negative for large text)

Line Height:
  - Body: 1.6
  - UI Elements: 1.4


