║  7. BORDERS & RADIUS                                                        ║
╚═══════════════════════════════════════════════════════════════════════════════╝

Border Radius:
  --radius-sm: 10px      (inputs, buttons, small elements)
  --radius-md: 16px      (nav items, cards)
  --radius-lg: 24px       (main cards, containers)
  --radius-xl: 32px       (login card)
  --radius-full: 9999px   (pills, badges)

Borders:
  --border: rgba(148, 163, 184, 0.08)     (subtle)
  --border-light: rgba(148, 163, 184, 0.15) (slightly visible)


